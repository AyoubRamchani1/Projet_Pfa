{
    "name": "projet/pfa",
    "description": "Projet PFA - Tests PHPUnit",
    "type": "project",
    "require": {
        "php": ">=8.2",
        "ext-pdo": "*",
        "ext-pdo_mysql": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.5"
    },
  "autoload": {
    "classmap": [
        "controller/",
        "model/",
        "admin/",
        "cache/",
        "view/",
        "description page/",
        "home page/"
    ]
},
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "config": {
        "optimize-autoloader": true
    }
}